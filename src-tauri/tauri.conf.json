{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WOLF Attendance",
  "version": "3.1.0",
  "identifier": "com.wolf.attendance",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WOLF Attendance",
        "width": 1280,
        "height": 850,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Patel",
    "category": "Education",
    "shortDescription": "Minimum-days attendance planner",
    "longDescription": "WOLF Attendance tells you the fewest college days to attend while keeping every subject (lectures and labs) above its attendance requirement.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "WOLF Attendance",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
