# Copy to `.env` and fill in from Supabase → Settings → API.
# `.env` is gitignored; this example file is not.

# The anon key is meant to be public — Row Level Security is what protects the
# data. Never put the `service_role` key in here: anything prefixed with VITE_ is
# inlined into the client bundle and readable by anyone who opens the app.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
