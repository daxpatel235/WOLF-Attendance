# Dependencies
node_modules/

# Frontend build output (Vite → dist/, embedded by Tauri at build time)
dist/

# Rust / Tauri build output
# Bare `target/` matches the build dir of every crate (src-tauri, wolf-core, …)
target/
src-tauri/gen/schemas/

# Logs & debug
*.log
npm-debug.log*
yarn-error.log*

# Secrets / local config (bring-your-own-key is stored in app userData, not here)
.env
.env.*
!.env.example

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/
